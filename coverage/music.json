      "projection": {"document": "detail", "path": "data.links"},
      "references": [{"name": "The Beatles", "external_ids": {"musicbrainz": "b10bbbfc-cf9e-42e0-be17-e2c3e1d2600d"}, "expected_providers": ["musicbrainz"]}]
    },
    {
      "id": "music.artist.images", "kind": "artist", "category": "fact",
      "description": "Portrait, fanart, logo, background, and provider avatar candidates receive opaque IDs and retain provenance.",
      "providers": ["wikidata", "discogs", "deezer", "fanart", "apple"],
      "projection": {"document": "detail", "path": "data.images"},
      "references": [{"name": "Björk", "external_ids": {"musicbrainz": "87c5dedd-371d-4a53-9f7f-80522fb7f3cb"}, "expected_providers": ["deezer", "wikidata"]}]
    },
    {
      "id": "music.artist.popularity", "kind": "artist", "category": "fact",
      "description": "Listeners, plays, fans, followers, provider rank, and catalog counts remain separate provider-specific metrics.",
      "providers": ["lastfm", "deezer", "discogs", "apple", "musicbrainz"],
      "projection": {"document": "detail", "path": "data.metrics"},
      "references": [{"name": "The Beatles", "external_ids": {"musicbrainz": "b10bbbfc-cf9e-42e0-be17-e2c3e1d2600d"}, "expected_providers": ["lastfm", "deezer"]}]
    },
    {
      "id": "music.artist.relationships.members", "kind": "artist", "category": "relationship",
      "description": "Group membership and artist-group relations retain provider target identity, role, activity state, and source without name-merging targets.",
      "providers": ["musicbrainz", "discogs", "wikidata"],
      "projection": {"document": "detail", "path": "data.relationships"},
      "references": [{"name": "The Beatles", "external_ids": {"musicbrainz": "b10bbbfc-cf9e-42e0-be17-e2c3e1d2600d"}, "expected_providers": ["discogs"]}]
    },
    {
      "id": "music.artist.discography.mixed", "kind": "artist", "category": "relationship",
      "description": "Artist discographies cluster release-group evidence across scripts and storefront editions. MusicBrainz, direct Apple, and direct Deezer artist records can anchor catalogs; unclaimed same-name pages still require unique overlap, exact supplied release IDs are credit-checked, Discogs issues require corroboration, issued-release track overlap can deduplicate regional release groups in presentation, and Last.fm can corroborate but never create a release.",
      "providers": ["musicbrainz", "discogs", "apple", "deezer", "lastfm"],
      "projection": {"document": "relations", "path": "discography"},
      "references": [{"name": "ano", "external_ids": {"musicbrainz": "ebb4513e-4aab-4ac9-a949-14e77bb7b836"}, "expected_providers": ["musicbrainz", "discogs", "apple"]}]
    },
    {
      "id": "music.artist.discography.storefront_freshness", "kind": "artist", "category": "relationship",
      "description": "A current digital-only release from a directly ingested or independently anchored storefront artist catalog becomes a canonical, provenance-bearing release group even when MusicBrainz does not list the artist or release.",
      "providers": ["apple", "deezer", "musicbrainz"],
      "projection": {"document": "relations", "path": "discography"},
      "references": [{"name": "ATARASHII GAKKO! — Oi AG!", "external_ids": {"musicbrainz": "12a43a61-e31a-4cac-92a6-c95ce9cdfe3c"}, "expected_providers": ["deezer"]}]
    },
    {
      "id": "music.artist.similar", "kind": "artist", "category": "relationship",
      "description": "Similar-artist recommendations retain provider target identity and score and never imply canonical equivalence.",
      "providers": ["lastfm"],
      "projection": {"document": "detail", "path": "data.similar_artists"},
      "references": [{"name": "The Beatles", "external_ids": {"musicbrainz": "b10bbbfc-cf9e-42e0-be17-e2c3e1d2600d"}, "expected_providers": ["lastfm"]}]
    },
    {
      "id": "music.artist.top_tracks", "kind": "artist", "category": "relationship",
      "description": "Last.fm's ranked top-track snapshot retains play and listener evidence, reports upstream truncation, links existing MusicBrainz recordings at read time, and never creates recordings merely to fill a ranking.",
      "providers": ["lastfm", "musicbrainz", "system"],
      "projection": {"document": "top_tracks", "path": "results"},
      "references": [{"name": "The Beatles", "external_ids": {"musicbrainz": "b10bbbfc-cf9e-42e0-be17-e2c3e1d2600d"}, "expected_providers": ["lastfm"]}]
    },
    {
      "id": "music.release_group.boundary", "kind": "release_group", "category": "capability",
      "description": "The abstract album/single/EP concept remains distinct from issued releases and provider catalog albums.",
      "providers": ["system", "musicbrainz"],
      "projection": {"document": "detail", "path": "kind"},
      "references": [{"name": "Abbey Road", "external_ids": {"musicbrainz": "9162580e-5df4-32de-80cc-f45a8d8a9b1d"}, "expected_providers": ["system"]}]
    },
    {
      "id": "music.release_group.images", "kind": "release_group", "category": "fact",
      "description": "Front covers, back covers, booklets, media/disc scans, spines, obi strips, trays, stickers, and other typed Cover Art Archive images retain opaque IDs and provider provenance.",
      "providers": ["coverartarchive", "discogs", "apple", "deezer", "fanart"],
      "projection": {"document": "detail", "path": "data.images"},
      "references": [{"name": "Abbey Road", "external_ids": {"musicbrainz": "9162580e-5df4-32de-80cc-f45a8d8a9b1d"}, "expected_providers": ["coverartarchive"]}]
    },
    {
      "id": "music.release.boundary", "kind": "release", "category": "capability",
      "description": "Country/date/label/barcode/catalog-number/format editions remain distinct beneath a release group.",
      "providers": ["system", "musicbrainz", "discogs", "apple", "deezer"],
      "projection": {"document": "detail", "path": "kind"},
      "references": [{"name": "Abbey Road UK LP", "external_ids": {"musicbrainz": "31765b9f-e969-4257-855f-c7ea1f657b2a"}, "expected_providers": ["system"]}]
    },
    {
      "id": "music.recording_track.boundary", "kind": "recording", "category": "capability",
      "description": "A captured recording remains distinct from every release-track placement and provider song object.",
      "providers": ["system", "musicbrainz", "apple", "deezer"],
      "projection": {"document": "detail", "path": "kind"},
      "references": [{"name": "Come Together", "external_ids": {"musicbrainz": "485bbe7f-d0f7-4ffe-8adb-0f1093dd2dbf"}, "expected_providers": ["system"]}]
    },
    {
      "id": "music.recording.discovery_standalone", "kind": "recording", "category": "capability",
      "description": "Standalone recordings are ranked with artist, duration, ISRC, and release evidence and resolve through the existing generic discovery contract.",
      "providers": ["musicbrainz"],
      "projection": {"document": "detail", "path": "data"},
      "references": [{"name": "普変", "external_ids": {"musicbrainz": "72feb5de-7912-4ad4-b507-21a1d5e199fd"}, "expected_providers": ["musicbrainz"]}]
    },
    {
      "id": "music.recording.fingerprint.preview", "kind": "recording", "category": "fact",
      "description": "Verified provider previews produce versioned raw Chromaprint evidence without retaining preview audio or signed URLs.",
      "providers": ["apple", "deezer"],
      "projection": {"document": "fingerprints", "path": "items"},
      "references": [{"name": "Come Together", "external_ids": {"musicbrainz": "485bbe7f-d0f7-4ffe-8adb-0f1093dd2dbf"}, "expected_providers": ["deezer"]}]
    },
    {
      "id": "music.recording.lyrics.lrclib", "kind": "recording", "category": "fact",
      "description": "Plain, synchronized, and instrumental LRCLIB evidence retains its record ID, response observation, checksum, and retrieval time.",
      "providers": ["lrclib"],
      "projection": {"document": "lyrics", "path": "items"},
      "references": [{"name": "Come Together", "external_ids": {"musicbrainz": "485bbe7f-d0f7-4ffe-8adb-0f1093dd2dbf"}, "expected_providers": ["lrclib"]}]
    },
    {
      "id": "music.recording.fingerprint.client_match", "kind": "recording", "category": "capability",
      "description": "A short-lived durable match job compares submitted Chromaprint evidence without retaining the client fingerprint.",
      "providers": ["system", "apple", "deezer"],
      "projection": {"document": "fingerprint_match", "path": "candidates"},
      "references": [{"name": "Fuhen", "external_ids": {"musicbrainz": "72feb5de-7912-4ad4-b507-21a1d5e199fd"}, "expected_providers": ["system"]}]
    },
    {
      "id": "music.recording.fingerprint.acoustid", "kind": "recording", "category": "capability",
      "description": "AcoustID evidence returns canonical Heya recording IDs or short-lived opaque candidate references and never establishes identity by score alone or exposes provider routing.",
      "providers": ["acoustid", "musicbrainz"],
      "projection": {"document": "fingerprint_match", "path": "candidates.candidate_ref"},
      "references": [{"name": "Fuhen", "external_ids": {"musicbrainz": "72feb5de-7912-4ad4-b507-21a1d5e199fd"}, "expected_providers": ["acoustid"]}]
    },
    {
      "id": "music.work.boundary", "kind": "musical_work", "category": "capability",
      "description": "The underlying composition and classical catalogue identity remain distinct from recordings and release tracks.",
