      "projection": {"document": "detail", "path": "data.names"},
      "references": [{"name": "Björk", "external_ids": {"musicbrainz": "87e748f1-49d8-47d5-8e9a-66f7d9705886"}, "expected_providers": ["musicbrainz"]}]
    },
    {
