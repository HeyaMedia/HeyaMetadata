{
  "schema_version": 1,
  "entries": [
    {
      "id": "music.artist.identity.external_ids", "kind": "artist", "category": "relationship",
      "description": "Explicit cross-provider artist IDs become provenance-bearing claims; names never create automatic identity.",
      "providers": ["musicbrainz", "discogs", "deezer", "apple", "wikidata", "lastfm"],
      "projection": {"document": "detail", "path": "external_ids"},
      "references": [{"name": "The Beatles", "external_ids": {"musicbrainz": "b10bbbfc-cf9e-42e0-be17-e2c3e1d2600d", "discogs": "82730", "deezer": "1", "apple": "136975", "wikidata": "Q1299"}, "expected_providers": ["musicbrainz"]}]
    },
    {
      "id": "music.artist.names.localized", "kind": "artist", "category": "fact",
      "description": "Display, sort, legal, credited, translated, native-script, search-hint, and historical names retain locale and type.",
