{
  "schema_version": 1,
  "entries": [
    {
      "id": "music.artist.identity.external_ids", "kind": "artist", "category": "relationship",
      "description": "Explicit cross-provider artist IDs become provenance-bearing claims; names never create automatic identity.",
      "providers": ["musicbrainz", "discogs", "deezer", "apple", "wikidata", "lastfm"],
      "projection": {"document": "detail", "path": "external_ids"},
      "references": [{"name": "The Beatles", "external_ids": {"musicbrainz": "b10bbbfc-cf9e-42e0-be17-e2c3e1d2600d", "discogs": "82730", "deezer": "1", "apple": "136975", "wikidata": "Q1299"}, "expected_providers": ["musicbrainz"]}]
    },
    {
      "id": "music.artist.names.localized", "kind": "artist", "category": "fact",
      "description": "Display, sort, legal, credited, translated, native-script, search-hint, and historical names retain locale and type.",
      "providers": ["musicbrainz", "discogs", "wikidata", "apple", "deezer", "lastfm"],
      "projection": {"document": "detail", "path": "data.names"},
      "references": [{"name": "Björk", "external_ids": {"musicbrainz": "87c5dedd-371d-4a53-9f7f-80522fb7f3cb"}, "expected_providers": ["musicbrainz"]}]
    },
    {
      "id": "music.artist.classification.type_gender", "kind": "artist", "category": "fact",
      "description": "Person, group, orchestra, choir, character, and other source types remain distinct; gender is retained only when supplied.",
      "providers": ["musicbrainz", "wikidata"],
      "projection": {"document": "detail", "path": "data.classification"},
      "references": [{"name": "Björk", "external_ids": {"musicbrainz": "87c5dedd-371d-4a53-9f7f-80522fb7f3cb"}, "expected_providers": ["musicbrainz"]}]
    },
    {
      "id": "music.artist.lifecycle", "kind": "artist", "category": "fact",
      "description": "Birth, death, formation, dissolution, begin/end areas, ended state, and partial date precision retain source provenance.",
      "providers": ["musicbrainz", "wikidata", "discogs"],
      "projection": {"document": "detail", "path": "data.lifecycle"},
      "references": [{"name": "The Beatles", "external_ids": {"musicbrainz": "b10bbbfc-cf9e-42e0-be17-e2c3e1d2600d"}, "expected_providers": ["musicbrainz"]}]
    },
    {
      "id": "music.artist.areas", "kind": "artist", "category": "fact",
      "description": "Country, primary area, begin area, and end area preserve provider IDs and ISO codes.",
      "providers": ["musicbrainz", "wikidata"],
      "projection": {"document": "detail", "path": "data.areas"},
      "references": [{"name": "The Beatles", "external_ids": {"musicbrainz": "b10bbbfc-cf9e-42e0-be17-e2c3e1d2600d"}, "expected_providers": ["musicbrainz"]}]
    },
    {
      "id": "music.artist.biographies", "kind": "artist", "category": "fact",
      "description": "Short descriptions and long biographies remain localized, markup-aware, and independently attributable.",
      "providers": ["lastfm", "wikidata", "discogs"],
      "projection": {"document": "detail", "path": "data.biographies"},
      "references": [{"name": "The Beatles", "external_ids": {"musicbrainz": "b10bbbfc-cf9e-42e0-be17-e2c3e1d2600d"}, "expected_providers": ["lastfm", "wikidata"]}]
    },
    {
      "id": "music.artist.genres_tags", "kind": "artist", "category": "fact",
      "description": "Genres and free-form tags retain provider counts/weights instead of being flattened into an unscored universal list.",
      "providers": ["musicbrainz", "lastfm", "apple", "deezer", "discogs", "wikidata"],
      "projection": {"document": "detail", "path": "data.genres"},
      "references": [{"name": "The Beatles", "external_ids": {"musicbrainz": "b10bbbfc-cf9e-42e0-be17-e2c3e1d2600d"}, "expected_providers": ["musicbrainz", "lastfm"]}]
    },
    {
      "id": "music.artist.links", "kind": "artist", "category": "fact",
      "description": "Official, social, streaming, purchase, lyrics, encyclopedia, and database links retain relationship type and source.",
