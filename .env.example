HEYA_METADATA_HOST=0.0.0.0
HEYA_METADATA_PORT=3030
HEYA_METADATA_LOG_LEVEL=info
HEYA_METADATA_LOG_FORMAT=text
HEYA_METADATA_DATABASE_URL=postgres://heya_metadata:heya_metadata_dev@127.0.0.1:5441/heya_metadata?sslmode=disable
HEYA_METADATA_REDIS_URL=redis://127.0.0.1:6380/0
HEYA_METADATA_WORKER_MAX_WORKERS=8

# RustFS / S3. Put credentials in .env.local, which is gitignored.
HEYA_METADATA_S3_ENDPOINT=https://s3-api.karbowiak.dk
HEYA_METADATA_S3_REGION=us-east-1
HEYA_METADATA_S3_BUCKET=heyamedia
HEYA_METADATA_S3_PREFIX=data
HEYA_METADATA_S3_ACCESS_KEY_ID=
HEYA_METADATA_S3_SECRET_ACCESS_KEY=
HEYA_METADATA_S3_PATH_STYLE=true
HEYA_METADATA_S3_AUTO_CREATE_BUCKET=false

# Provider credentials belong in .env.local.
HEYA_METADATA_TMDB_TOKEN=
HEYA_METADATA_TMDB_BASE_URL=https://api.themoviedb.org/3
HEYA_METADATA_TMDB_LANGUAGE=en-US
HEYA_METADATA_OMDB_API_KEY=
HEYA_METADATA_OMDB_BASE_URL=https://www.omdbapi.com/
