HEYA_METADATA_HOST=0.0.0.0
HEYA_METADATA_PORT=3030
HEYA_METADATA_LOG_LEVEL=info
HEYA_METADATA_LOG_FORMAT=text
HEYA_METADATA_DATABASE_URL=postgres://heya_metadata:heya_metadata_dev@127.0.0.1:5441/heya_metadata?sslmode=disable
HEYA_METADATA_REDIS_URL=redis://127.0.0.1:6380/0
HEYA_METADATA_WORKER_MAX_WORKERS=8

# RustFS / S3. Put credentials in .env.local, which is gitignored.
HEYA_METADATA_S3_ENDPOINT=https://s3-api.karbowiak.dk
HEYA_METADATA_S3_REGION=us-east-1
HEYA_METADATA_S3_BUCKET=heyamedia
HEYA_METADATA_S3_PREFIX=data
HEYA_METADATA_S3_ACCESS_KEY_ID=
HEYA_METADATA_S3_SECRET_ACCESS_KEY=
HEYA_METADATA_S3_PATH_STYLE=true
HEYA_METADATA_S3_AUTO_CREATE_BUCKET=false

# Provider credentials belong in .env.local.
HEYA_METADATA_TMDB_TOKEN=
HEYA_METADATA_TMDB_BASE_URL=https://api.themoviedb.org/3
HEYA_METADATA_TMDB_LANGUAGE=en-US
HEYA_METADATA_OMDB_API_KEY=
HEYA_METADATA_OMDB_BASE_URL=https://www.omdbapi.com/
HEYA_METADATA_TVDB_API_KEY=
HEYA_METADATA_TVDB_BASE_URL=https://api4.thetvdb.com/v4
HEYA_METADATA_FANART_API_KEY=
HEYA_METADATA_FANART_BASE_URL=https://webservice.fanart.tv/v3.2
HEYA_METADATA_MUSICBRAINZ_BASE_URL=https://musicbrainz.org/ws/2
HEYA_METADATA_MUSICBRAINZ_REQUESTS_PER_SECOND=1
HEYA_METADATA_MUSICBRAINZ_USER_AGENT=HeyaMetadata/dev (https://github.com/HeyaMedia/HeyaMetadata)
HEYA_METADATA_APPLE_BASE_URL=https://itunes.apple.com
HEYA_METADATA_APPLE_MUSIC_BASE_URL=https://api.music.apple.com/v1
HEYA_METADATA_APPLE_DEVELOPER_TOKEN=
HEYA_METADATA_APPLE_COUNTRY=US
HEYA_METADATA_APPLE_REQUESTS_PER_SECOND=0.333333
HEYA_METADATA_DEEZER_BASE_URL=https://api.deezer.com
HEYA_METADATA_DEEZER_REQUESTS_PER_SECOND=5
HEYA_METADATA_DISCOGS_API_KEY=
HEYA_METADATA_DISCOGS_BASE_URL=https://api.discogs.com
HEYA_METADATA_DISCOGS_REQUESTS_PER_SECOND=1
HEYA_METADATA_DISCOGS_USER_AGENT=HeyaMetadata/dev +https://github.com/HeyaMedia/HeyaMetadata
HEYA_METADATA_LASTFM_API_KEY=
HEYA_METADATA_LASTFM_BASE_URL=https://ws.audioscrobbler.com/2.0/
HEYA_METADATA_LASTFM_REQUESTS_PER_SECOND=5
HEYA_METADATA_ANIDB_CLIENT=
HEYA_METADATA_ANIDB_CLIENT_VERSION=1
HEYA_METADATA_ANIDB_BASE_URL=http://api.anidb.net:9001/httpapi
HEYA_METADATA_ANIDB_TITLES_URL=https://anidb.net/api/anime-titles.xml.gz
HEYA_METADATA_ANIDB_USER_AGENT=heya-media/1.0 anidb-titles-sync
HEYA_METADATA_TVMAZE_BASE_URL=https://api.tvmaze.com
HEYA_METADATA_TVMAZE_REQUESTS_PER_SECOND=2
HEYA_METADATA_WIKIDATA_BASE_URL=https://www.wikidata.org
HEYA_METADATA_WIKIDATA_REQUESTS_PER_SECOND=1
HEYA_METADATA_WIKIDATA_USER_AGENT=HeyaMetadata/dev (https://github.com/HeyaMedia/HeyaMetadata)
HEYA_METADATA_OPENOPUS_BASE_URL=https://api.openopus.org
HEYA_METADATA_OPENOPUS_REQUESTS_PER_SECOND=2
